# Example environment (no secrets)

Copy to `.env` locally. Never commit real passwords, API keys, or tokens.

# Postgres
POSTGRES_USER=trade
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=trade
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://trade:changeme_dev_only@postgres:5432/trade

# Redis
REDIS_URL=redis://redis:6379/0

# Redpanda / Kafka-compatible
KAFKA_BROKERS=redpanda:9092

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Frontend (public, non-secret)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# App
APP_ENV=dev
