# Example environment (no secrets)

Copy to `.env` locally. Never commit real passwords, API keys, or tokens.

# Postgres
POSTGRES_USER=trade
POSTGRES_PASSWORD=changeme_dev_only
POSTGRES_DB=trade
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://trade:changeme_dev_only@postgres:5432/trade

# Redis
REDIS_URL=redis://redis:6379/0

# Redpanda / Kafka-compatible
KAFKA_BROKERS=redpanda:9092

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Frontend (public, non-secret)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# App
APP_ENV=dev

# Paper venue (Gateway) — default internal matcher for CI
# internal | binance_testnet
PAPER_VENUE_MODE=internal
# Only used when PAPER_VENUE_MODE=binance_testnet (must stay Spot Testnet host)
# BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision
# Put Binance *testnet* API keys via POST /v1/accounts/{id}/api-keys — never commit keys.

# Prod-live capital + Binance mainnet adapter — default OFF (CI must stay off)
LIVE_MAX_NAV_PCT=5
# Owner 2026-07-23 LIVE-VENUE-ADAPTER — set locally only (never commit real .env)
# LIVE_NAV_QUOTE=100000
LIVE_TRADING_ENABLED=false
PHASE2_GATES_ACK=false
# off | binance_mainnet
LIVE_VENUE_MODE=off
# BINANCE_MAINNET_BASE_URL=https://api.binance.com
# Mainnet API keys via POST /v1/accounts/{id}/api-keys on testnet=false — never commit keys.

