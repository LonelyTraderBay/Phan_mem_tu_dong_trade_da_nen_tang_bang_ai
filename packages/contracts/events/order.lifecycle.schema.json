{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trade-ai.local/schemas/order.lifecycle.v1.json",
  "title": "order.*",
  "type": "object",
  "required": [
    "trace_id",
    "schema_version",
    "produced_at_utc",
    "producer_service",
    "client_order_id",
    "symbol",
    "side",
    "state",
    "risk_check_id"
  ],
  "properties": {
    "trace_id": { "type": "string" },
    "schema_version": { "type": "integer" },
    "produced_at_utc": { "type": "string" },
    "producer_service": { "type": "string" },
    "client_order_id": { "type": "string" },
    "symbol": { "type": "string" },
    "side": { "type": "string", "enum": ["buy", "sell"] },
    "state": { "type": "string" },
    "risk_check_id": { "type": "string" }
  },
  "additionalProperties": true
}
