{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mvp-capability-matrix.schema.json",
  "title": "MVPCapabilityMatrix",
  "description": "Canonical schema for Phase-1 MVP capability matrix (aligned with data-model.md). Deferred rows SHOULD set phase_return; In-MVP rows MUST set lane other than n_a unless shared docs-only.",
  "type": "object",
  "required": ["version", "updated_at", "primary_market", "operator_profile", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "updated_at": { "type": "string", "format": "date" },
    "primary_market": { "type": "string", "enum": ["crypto_paper"] },
    "operator_profile": { "type": "string", "enum": ["solo_paper"] },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Capability" }
    }
  },
  "definitions": {
    "Capability": {
      "type": "object",
      "required": ["id", "name", "description", "status", "rationale", "lane", "contract_touch", "safety_critical"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 2 },
        "name": { "type": "string", "minLength": 2 },
        "description": { "type": "string", "minLength": 8 },
        "status": { "type": "string", "enum": ["in_mvp", "deferred"] },
        "rationale": { "type": "string", "minLength": 8 },
        "lane": { "type": "string", "enum": ["backend", "frontend", "both", "shared", "n_a"] },
        "contract_touch": { "type": "boolean" },
        "contract_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "OpenAPI operationIds, event subjects, or docs-only:* refs"
        },
        "phase_return": {
          "type": ["string", "null"],
          "description": "Required when status=deferred (e.g. phase-2|phase-3|phase-4)"
        },
        "safety_critical": { "type": "boolean" }
      }
    }
  }
}
